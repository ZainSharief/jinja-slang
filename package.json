{
  "name": "jinja-slang",
  "displayName": "Jinja Slang",
  "description": "Jinja2 templating for Slang shaders",
  "version": "0.0.3",
  "publisher": "zainsharief",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZainSharief/jinja-slang"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionDependencies": [
    "wholroyd.jinja",
    "shader-slang.slang-language-extension"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "jinja-slang",
      "aliases": ["Jinja Slang", "jinja-slang"],
      "extensions": [".slang.j2"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "./media/icon.png",
        "dark": "./media/icon.png"
      }
    }],
    "grammars": [{
      "language": "jinja-slang",
      "scopeName": "source.jinja-slang",
      "path": "./syntaxes/jinja-slang.tmLanguage.json"
    }]
  }
}
